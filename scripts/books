#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-}"

case "${COMMAND}" in
  health|verify|opds-url|kosync-url|proxy-commands|users|hardcover|import|sync-fixture|anna|status|restart)
    if [[ ${EUID} -ne 0 ]]; then
      exec sudo -E "$0" "$@"
    fi
    ;;
esac

export NODE_OPTIONS="${NODE_OPTIONS:+${NODE_OPTIONS} }--no-warnings"
exec node "${ROOT_DIR}/src/cli.js" "$@"
