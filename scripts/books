#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND="${1:-}"

case "${COMMAND}" in
  health|verify|web-url|opds-url|kosync-url|proxy-commands|users|requests)
    if [[ ${EUID} -ne 0 && ! -r /etc/books/books.env ]]; then
      exec sudo "$0" "$@"
    fi
    ;;
esac

usage() {
  cat <<'EOF'
Usage: ./scripts/books COMMAND [ARGS...]

Commands:
  status                 Show service status
  health                 Check local nginx, calibre, calibre-web, portal, Readest, and KOSync health
  verify [USER]          Run local production checks for routes and per-user auth
  restart                Restart services and reload nginx
  import [--convert] F   Import EPUB files into calibre
  sync-fixture           Generate and import the Books Sync Fixture EPUB
  anna ARGS...           Run Anna's Archive MCP/CLI through the configured env
  users ARGS...          Manage family users and credentials
  requests ARGS...       Review book requests
  web-url                Print the owner-only calibre-web URL
  opds-url               Print the OPDS URL for Crosspoint
  kosync-url             Print the KOSync URL for reading progress
  proxy-commands         Print documented exe.dev share commands
  install-skill          Install/symlink the repo books skill into CODEX_HOME
EOF
}

case "${COMMAND}" in
  status)
    systemctl --no-pager --full status books-calibre books-calibre-web books-portal books-kosync books-readest nginx
    ;;
  health)
    source /etc/books/books.env
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/healthz"
    curl -fsSI -u "${CALIBRE_OPDS_USER}:${CALIBRE_OPDS_PASSWORD}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/opds" | sed -n '1,12p'
    curl -fsS -H "Accept: application/vnd.koreader.v1+json" "http://127.0.0.1:${BOOKS_PROXY_PORT}/kosync/healthcheck"
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/runtime-config.js" >/dev/null
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/library" >/dev/null
    curl -fsS -H "X-ExeDev-Email: ${BOOKS_ALLOWED_EMAIL}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/" >/dev/null
    ;;
  verify)
    shift || true
    source /etc/books/books.env
    user="${1:-}"
    if [[ -z "${user}" ]]; then
      user="$(BOOKS_ACCOUNTS_DB="${BOOKS_ACCOUNTS_DB}" python3 - <<'PY'
import os
import sqlite3

conn = sqlite3.connect(os.environ["BOOKS_ACCOUNTS_DB"])
row = conn.execute("select slug from accounts where status='active' order by slug limit 1").fetchone()
print(row[0] if row else "")
PY
)"
    fi
    if [[ -z "${user}" ]]; then
      echo "No active user exists. Create one with ./scripts/books users create \"Name\" --email person@example.com" >&2
      exit 1
    fi

    payload="$(/opt/books/bin/books-users show "${user}" --json)"
    field() {
      python3 -c 'import json,sys; print(json.load(sys.stdin)[sys.argv[1]])' "$1" <<<"${payload}"
    }
    setup_user="$(field setup_user)"
    setup_password="$(field setup_password)"
    opds_user="$(field opds_user)"
    opds_password="$(field opds_password)"
    readest_email="$(field readest_email)"
    readest_password="$(field readest_password)"
    kosync_user="$(field kosync_user)"
    kosync_password="$(field kosync_password)"
    kosync_key="$(printf '%s' "${kosync_password}" | md5sum | awk '{print $1}')"
    kosync_verify_doc="0123456789abcdef0123456789abcdef"

    printf 'Checking services...\n'
    systemctl is-active --quiet books-calibre
    systemctl is-active --quiet books-calibre-web
    systemctl is-active --quiet books-portal
    systemctl is-active --quiet books-kosync
    systemctl is-active --quiet books-readest
    systemctl is-active --quiet nginx

    printf 'Checking portal and owner gate...\n'
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/healthz" >/dev/null
    curl -fsS -H "X-ExeDev-Email: ${BOOKS_ALLOWED_EMAIL}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/" >/dev/null
    public_status="$(curl -sS -o /dev/null -w '%{http_code}' "http://127.0.0.1:${BOOKS_PROXY_PORT}/")"
    [[ "${public_status}" == "302" ]]
    setup_status="$(curl -sS -o /dev/null -w '%{http_code}' "http://127.0.0.1:${BOOKS_PROXY_PORT}/setup/${user}")"
    [[ "${setup_status}" == "401" ]]
    curl -fsS -u "${setup_user}:${setup_password}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/setup/${user}" >/dev/null

    printf 'Checking OPDS...\n'
    curl -fsSI -u "${opds_user}:${opds_password}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/opds" >/dev/null
    curl -fsSI -u "${opds_user}:${opds_password}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/catalog" >/dev/null

    printf 'Checking Readest Web...\n'
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/runtime-config.js" | grep -q "SUPABASE\\|READEST_RUNTIME_CONFIG"
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/library" >/dev/null
    curl -fsS "http://127.0.0.1:${BOOKS_PROXY_PORT}/auth/v1/health" >/dev/null
    readest_login="$(curl -fsS -X POST "http://127.0.0.1:${BOOKS_PROXY_PORT}/auth/v1/token?grant_type=password" \
      -H "apikey: ${READEST_ANON_KEY}" \
      -H "Content-Type: application/json" \
      -d "{\"email\":\"${readest_email}\",\"password\":\"${readest_password}\"}")"
    python3 -c 'import json,sys; data=json.load(sys.stdin); assert data["user"]["email"] == sys.argv[1]; assert data["access_token"]' "${readest_email}" <<<"${readest_login}"

    printf 'Checking KOSync...\n'
    curl -fsS -H "Accept: application/vnd.koreader.v1+json" "http://127.0.0.1:${BOOKS_PROXY_PORT}/kosync/healthcheck" >/dev/null
    curl -fsS -H "Accept: application/vnd.koreader.v1+json" -H "x-auth-user: ${kosync_user}" -H "x-auth-key: ${kosync_key}" "http://127.0.0.1:${BOOKS_PROXY_PORT}/kosync/users/auth" >/dev/null
    curl -fsS -X POST -H "Content-Type: application/json" \
      -d "{\"serverUrl\":\"https://${BOOKS_PUBLIC_HOST}/kosync\",\"endpoint\":\"/users/auth\",\"method\":\"GET\",\"headers\":{\"X-Auth-User\":\"${kosync_user}\",\"X-Auth-Key\":\"${kosync_key}\"}}" \
      "http://127.0.0.1:${BOOKS_PROXY_PORT}/api/kosync" >/dev/null
    curl -fsS -X POST -H "Content-Type: application/json" \
      -d "{\"serverUrl\":\"https://${BOOKS_PUBLIC_HOST}/kosync\",\"endpoint\":\"/syncs/progress\",\"method\":\"PUT\",\"headers\":{\"X-Auth-User\":\"${kosync_user}\",\"X-Auth-Key\":\"${kosync_key}\"},\"body\":{\"document\":\"${kosync_verify_doc}\",\"progress\":\"/body/DocFragment[1]/p[1]\",\"percentage\":0.42,\"device\":\"books-verify\",\"device_id\":\"books-verify\"}}" \
      "http://127.0.0.1:${BOOKS_PROXY_PORT}/api/kosync" >/dev/null
    kosync_progress="$(curl -fsS -X POST -H "Content-Type: application/json" \
      -d "{\"serverUrl\":\"https://${BOOKS_PUBLIC_HOST}/kosync\",\"endpoint\":\"/syncs/progress/${kosync_verify_doc}\",\"method\":\"GET\",\"headers\":{\"X-Auth-User\":\"${kosync_user}\",\"X-Auth-Key\":\"${kosync_key}\"}}" \
      "http://127.0.0.1:${BOOKS_PROXY_PORT}/api/kosync")"
    python3 -c 'import json,sys; data=json.load(sys.stdin); assert data["document"] == sys.argv[1]; assert abs(float(data["percentage"]) - 0.42) < 0.001' "${kosync_verify_doc}" <<<"${kosync_progress}"

    printf 'Checking KOSync image pin...\n'
    docker image inspect "${KOSYNC_IMAGE}" >/dev/null

    printf 'ok: local production checks passed for %s\n' "${user}"
    ;;
  restart)
    sudo systemctl restart books-calibre
    sudo systemctl restart books-calibre-web
    sudo systemctl restart books-portal
    sudo systemctl restart books-kosync
    sudo systemctl restart books-readest
    sudo nginx -t
    sudo systemctl reload nginx
    ;;
  import)
    shift
    sudo /opt/books/bin/books-import "$@"
    ;;
  sync-fixture)
    shift
    sudo /opt/books/bin/books-sync-fixture "$@"
    ;;
  anna)
    shift
    sudo /opt/books/bin/books-annas "$@"
    ;;
  users)
    shift
    sudo /opt/books/bin/books-users "$@"
    ;;
  requests)
    shift
    sudo /opt/books/bin/books-users requests "$@"
    ;;
  web-url)
    source /etc/books/books.env
    printf 'https://%s/calibre/\n' "${BOOKS_PUBLIC_HOST}"
    printf 'username: %s\n' "${CALIBRE_WEB_ADMIN_USER}"
    printf 'password: stored in /etc/books/books.env as CALIBRE_WEB_ADMIN_PASSWORD\n'
    ;;
  opds-url)
    source /etc/books/books.env
    printf 'https://%s/opds\n' "${BOOKS_PUBLIC_HOST}"
    printf 'username: %s\n' "${CALIBRE_OPDS_USER}"
    printf 'password: stored in /etc/books/books.env as CALIBRE_OPDS_PASSWORD\n'
    ;;
  kosync-url)
    source /etc/books/books.env
    printf 'https://%s/kosync\n' "${BOOKS_PUBLIC_HOST}"
    ;;
  proxy-commands)
    source /etc/books/books.env
    vm="${BOOKS_PUBLIC_HOST%%.*}"
    cat <<EOF
Run these from your local machine, per exe.dev docs:

ssh exe.dev share port ${vm} ${BOOKS_PROXY_PORT}
ssh exe.dev share set-public ${vm}

To return to private access:
ssh exe.dev share set-private ${vm}
EOF
    ;;
  install-skill)
    "${ROOT_DIR}/scripts/install-skill"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
