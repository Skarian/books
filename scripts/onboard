#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_DIR=/etc/books
ENV_FILE="${ENV_DIR}/books.env"
OPT_DIR=/opt/books
OPT_BIN="${OPT_DIR}/bin"
NGINX_CONF=/etc/nginx/conf.d/books.conf
SYSTEMD_UNIT=/etc/systemd/system/books-calibre.service
CALIBRE_WEB_SYSTEMD_UNIT=/etc/systemd/system/books-calibre-web.service
PORTAL_SYSTEMD_UNIT=/etc/systemd/system/books-portal.service
KOSYNC_SYSTEMD_UNIT=/etc/systemd/system/books-kosync.service
READEST_SYSTEMD_UNIT=/etc/systemd/system/books-readest.service
ORIGINAL_ARGS=("$@")

if [[ ${EUID} -ne 0 ]]; then
  exec sudo -E "$0" "${ORIGINAL_ARGS[@]}"
fi

non_interactive=false
skip_start=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --non-interactive)
      non_interactive=true
      shift
      ;;
    --skip-start)
      skip_start=true
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage: ./scripts/onboard [--non-interactive] [--skip-start]

Installs and configures the personal books service:
  - official calibre binary
  - Calibre-Web web reader
  - Anna's Archive MCP/CLI binary
  - /etc/books/books.env
  - /srv/books data directories
  - books-calibre systemd service
  - nginx gate on BOOKS_PROXY_PORT
  - repo-local Codex books skill symlink
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 2
      ;;
  esac
done

load_existing_env() {
  if [[ -r "${ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
    set +a
  fi
}

rand_secret() {
  local length="${1:-24}"
  local value
  value="$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c "${length}" || true)"
  printf '%s' "${value}"
}

jwt_for_role() {
  local role="$1"
  local secret="$2"
  python3 - "$role" "$secret" <<'PY'
import base64
import hashlib
import hmac
import json
import sys

role, secret = sys.argv[1], sys.argv[2].encode()

def b64url(raw):
    return base64.urlsafe_b64encode(raw).decode().rstrip("=")

header = {"alg": "HS256", "typ": "JWT"}
payload = {"role": role}
head = b64url(json.dumps(header, separators=(",", ":")).encode())
body = b64url(json.dumps(payload, separators=(",", ":")).encode())
sig = b64url(hmac.new(secret, f"{head}.{body}".encode(), hashlib.sha256).digest())
print(f"{head}.{body}.{sig}")
PY
}

ask() {
  local name="$1"
  local prompt="$2"
  local default="$3"
  local value

  if [[ "${non_interactive}" == true ]]; then
    printf -v "${name}" '%s' "${default}"
    return
  fi

  read -r -p "${prompt} [${default}]: " value
  printf -v "${name}" '%s' "${value:-${default}}"
}

ask_secret() {
  local name="$1"
  local prompt="$2"
  local existing="${3:-}"
  local value generated

  if [[ "${non_interactive}" == true ]]; then
    if [[ -n "${existing}" ]]; then
      printf -v "${name}" '%s' "${existing}"
    else
      generated="$(rand_secret)"
      printf -v "${name}" '%s' "${generated}"
    fi
    return
  fi

  if [[ -n "${existing}" ]]; then
    read -r -s -p "${prompt} [leave blank to keep existing]: " value
    echo
    printf -v "${name}" '%s' "${value:-${existing}}"
  else
    read -r -s -p "${prompt} [leave blank to generate]: " value
    echo
    if [[ -z "${value}" ]]; then
      value="$(rand_secret)"
      echo "Generated ${name}."
    fi
    printf -v "${name}" '%s' "${value}"
  fi
}

ask_optional_secret() {
  local name="$1"
  local prompt="$2"
  local existing="${3:-}"
  local value

  if [[ "${non_interactive}" == true ]]; then
    printf -v "${name}" '%s' "${existing}"
    return
  fi

  if [[ -n "${existing}" ]]; then
    read -r -s -p "${prompt} [leave blank to keep existing]: " value
    echo
    printf -v "${name}" '%s' "${value:-${existing}}"
  else
    read -r -s -p "${prompt} [leave blank to skip for now]: " value
    echo
    printf -v "${name}" '%s' "${value}"
  fi
}

shell_quote() {
  local value="$1"
  printf "'%s'" "${value//\'/\'\\\'\'}"
}

sql_literal() {
  local value="$1"
  printf "'%s'" "${value//\'/\'\'}"
}

