ensure_env_permissions() {
  chown root:books "${ENV_FILE}"
  chmod 0640 "${ENV_FILE}"
}

ensure_packages() {
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y \
    ca-certificates \
    curl \
    docker.io \
    git \
    jq \
    nginx \
    python3 \
    python3-venv \
    sqlite3 \
    libmagic1 \
    wget \
    xdg-utils \
    xz-utils \
    libxcb-cursor0 \
    libopengl0
}

ensure_calibre() {
  local current_version=""
  if command -v ebook-convert >/dev/null 2>&1; then
    current_version="$(ebook-convert --version | awk 'NR==1 {gsub(/[()]/, "", $3); print $3}')"
  fi

  if [[ -n "${current_version}" && ( -z "${CALIBRE_VERSION:-}" || "${current_version}" == "${CALIBRE_VERSION}" ) ]]; then
    return
  fi

  if [[ -n "${current_version}" && -n "${CALIBRE_VERSION:-}" && "${current_version}" != "${CALIBRE_VERSION}" ]] && command -v calibre-uninstall >/dev/null 2>&1; then
    calibre-uninstall || true
  fi

  if [[ -n "${CALIBRE_VERSION:-}" ]]; then
    wget -nv -O- https://download.calibre-ebook.com/linux-installer.sh | sh /dev/stdin "version=${CALIBRE_VERSION}"
  else
    wget -nv -O- https://download.calibre-ebook.com/linux-installer.sh | sh /dev/stdin
  fi
}

ensure_calibre_web() {
  local venv="${OPT_DIR}/calibre-web-venv"
  local installed_version=""

  install -d -m 0755 "${OPT_DIR}"

  if [[ -x "${venv}/bin/cps" ]]; then
    installed_version="$("${venv}/bin/cps" --version 2>/dev/null | sed -nE 's/^Calibre-Web version: ([^ ]+).*/\1/p')"
  fi

  if [[ "${installed_version}" != "${CALIBRE_WEB_VERSION}" ]]; then
    rm -rf "${venv}"
    (umask 022 && python3 -m venv "${venv}")
    HOME=/root "${venv}/bin/pip" install --upgrade pip
    HOME=/root "${venv}/bin/pip" install "calibreweb==${CALIBRE_WEB_VERSION}"
  fi
  HOME=/root "${venv}/bin/pip" install "greenlet>=0.4.17,<3.3.0"
  chmod -R a+rX "${venv}"
}

annas_asset_suffix() {
  case "$(uname -m)" in
    x86_64|amd64) echo "linux_amd64" ;;
    aarch64|arm64) echo "linux_arm64" ;;
    armv7l|armv6l) echo "linux_arm" ;;
    *)
      echo "Unsupported architecture for annas-mcp: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

ensure_annas_mcp() {
  install -d -m 0755 "${OPT_BIN}"
  local version_no_v="${ANNAS_VERSION#v}"
  local suffix asset checksums url tmpdir
  suffix="$(annas_asset_suffix)"
  asset="annas-mcp_${version_no_v}_${suffix}.tar.xz"
  checksums="annas-mcp_${version_no_v}--checksums.txt"
  url="https://github.com/iosifache/annas-mcp/releases/download/${ANNAS_VERSION}"

  if [[ -x "${OPT_BIN}/annas-mcp" ]] && "${OPT_BIN}/annas-mcp" --version 2>/dev/null | grep -q "${version_no_v}"; then
    return
  fi

  tmpdir="$(mktemp -d)"
  curl -fsSLo "${tmpdir}/${asset}" "${url}/${asset}"
  curl -fsSLo "${tmpdir}/${checksums}" "${url}/${checksums}"
  (cd "${tmpdir}" && grep "  ${asset}$" "${checksums}" | sha256sum -c -)
  tar -xJf "${tmpdir}/${asset}" -C "${tmpdir}"
  install -m 0755 "$(find "${tmpdir}" -type f -name annas-mcp | head -n 1)" "${OPT_BIN}/annas-mcp"
  touch "${OPT_BIN}/.env"
  chmod 0644 "${OPT_BIN}/.env"
  rm -rf "${tmpdir}"
}

ensure_users_and_dirs() {
  if ! getent group books >/dev/null; then
    groupadd --system books
  fi
  if ! id books >/dev/null 2>&1; then
    useradd --system --gid books --home-dir "${BOOKS_DATA_DIR}" --shell /usr/sbin/nologin books
  fi
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    usermod -aG books "${SUDO_USER}" || true
  fi

  install -d -o books -g books -m 0750 "${BOOKS_DATA_DIR}" "${BOOKS_CONFIG_DIR}" "${BOOKS_LOG_DIR}"
  install -d -o books -g books -m 0750 "${CALIBRE_WEB_DIR}"
  install -d -o books -g books -m 0750 "${KOSYNC_DATA_DIR}" "${KOSYNC_DATA_DIR}/redis" "${KOSYNC_LOG_DIR}" "${KOSYNC_LOG_DIR}/redis" "${KOSYNC_LOG_DIR}/app"
  install -d -o books -g books -m 0750 "${READEST_DIR}" "${READEST_DIR}/volumes" "${READEST_DIR}/volumes/api" "${READEST_DIR}/volumes/db" "${READEST_DIR}/volumes/db/init"
  install -d -o books -g books -m 2770 "${BOOKS_LIBRARY_DIR}" "${BOOKS_DOWNLOAD_DIR}" "${BOOKS_IMPORT_DIR}" "${BOOKS_REQUESTS_DIR}"
  if [[ ! -f "${BOOKS_LIBRARY_DIR}/metadata.db" ]]; then
    runuser -u books -- calibredb --with-library "${BOOKS_LIBRARY_DIR}" list >/dev/null
  fi
}

ensure_calibre_web_db() {
  local old_user=""
  local calibre_dir_sql log_sql access_log_sql converter_sql binaries_sql admin_user_sql email_sql

  calibre_web_db_ready() {
    [[ -f "${CALIBRE_WEB_DB}" ]] &&
      sqlite3 "file:${CALIBRE_WEB_DB}?mode=ro" "select 1 from settings limit 1;" >/dev/null 2>&1
  }

  if ! calibre_web_db_ready; then
    rm -f "${CALIBRE_WEB_DB}" "${CALIBRE_WEB_GDRIVE_DB}"
    runuser -u books -- env HOME="${BOOKS_DATA_DIR}" \
      "${OPT_DIR}/calibre-web-venv/bin/cps" \
      -p "${CALIBRE_WEB_DB}" \
      -g "${CALIBRE_WEB_GDRIVE_DB}" \
      -i 127.0.0.1 \
      -o "${BOOKS_LOG_DIR}/calibre-web-bootstrap.log" >/tmp/books-calibre-web-bootstrap.log 2>&1 &
    local pid=$!
    for _ in $(seq 1 40); do
      if calibre_web_db_ready; then
        break
      fi
      sleep 0.5
    done
    kill "${pid}" 2>/dev/null || true
    wait "${pid}" 2>/dev/null || true
    if ! calibre_web_db_ready; then
      echo "Calibre-Web failed to bootstrap ${CALIBRE_WEB_DB}." >&2
      sed -n '1,160p' /tmp/books-calibre-web-bootstrap.log >&2 || true
      exit 1
    fi
  fi

  calibre_dir_sql="$(sql_literal "${BOOKS_LIBRARY_DIR}")"
  log_sql="$(sql_literal "${BOOKS_LOG_DIR}/calibre-web.log")"
  access_log_sql="$(sql_literal "${BOOKS_LOG_DIR}/calibre-web-access.log")"
  converter_sql="$(sql_literal "/usr/bin/ebook-convert")"
  binaries_sql="$(sql_literal "/opt/calibre/")"
  admin_user_sql="$(sql_literal "${CALIBRE_WEB_ADMIN_USER}")"
  email_sql="$(sql_literal "${BOOKS_ALLOWED_EMAIL}")"

  sqlite3 "${CALIBRE_WEB_DB}" <<SQL
update settings
set config_calibre_dir = ${calibre_dir_sql},
    config_port = ${CALIBRE_WEB_PORT},
    config_external_port = 443,
    config_calibre_web_title = 'Books',
    config_logfile = ${log_sql},
    config_access_log = 1,
    config_access_logfile = ${access_log_sql},
    config_uploading = 0,
    config_anonbrowse = 0,
    config_public_reg = 0,
    config_remote_login = 0,
    config_kobo_sync = 0,
    config_kobo_proxy = 0,
    config_register_email = 0,
    config_converterpath = ${converter_sql},
    config_binariesdir = ${binaries_sql},
    config_embed_metadata = 0,
    config_updatechannel = 0,
    config_password_policy = 0,
    config_ratelimiter = 1
where id = 1;
SQL

  if sqlite3 "${CALIBRE_WEB_DB}" "select 1 from user where name=${admin_user_sql} limit 1;" | grep -q 1; then
    "${OPT_DIR}/calibre-web-venv/bin/cps" -p "${CALIBRE_WEB_DB}" -g "${CALIBRE_WEB_GDRIVE_DB}" -s "${CALIBRE_WEB_ADMIN_USER}:${CALIBRE_WEB_ADMIN_PASSWORD}" >/dev/null
  else
    old_user="$(sqlite3 "${CALIBRE_WEB_DB}" "select name from user where id=1;")"
    "${OPT_DIR}/calibre-web-venv/bin/cps" -p "${CALIBRE_WEB_DB}" -g "${CALIBRE_WEB_GDRIVE_DB}" -s "${old_user}:${CALIBRE_WEB_ADMIN_PASSWORD}" >/dev/null
    sqlite3 "${CALIBRE_WEB_DB}" "update user set name=${admin_user_sql}, email=${email_sql}, locale='en', default_language='all' where id=1;"
  fi

  chown -R books:books "${CALIBRE_WEB_DIR}"
  chmod 0750 "${CALIBRE_WEB_DIR}"
  chmod 0640 "${CALIBRE_WEB_DB}" "${CALIBRE_WEB_GDRIVE_DB}" 2>/dev/null || true
  touch "${BOOKS_LOG_DIR}/calibre-web.log" "${BOOKS_LOG_DIR}/calibre-web-access.log"
  chown books:books "${BOOKS_LOG_DIR}/calibre-web.log" "${BOOKS_LOG_DIR}/calibre-web-access.log"
  chmod 0644 "${BOOKS_LOG_DIR}/calibre-web.log" "${BOOKS_LOG_DIR}/calibre-web-access.log"
}

calibre_user_exists() {
  calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- list | grep -Fxq "$1"
}

ensure_calibre_user() {
  local user="$1"
  local password="$2"
  local readonly="$3"
  local can_change_password="$4"

  if calibre_user_exists "${user}"; then
    calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- chpass "${user}" "${password}"
  else
    if [[ "${readonly}" == "set" ]]; then
      calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- add "${user}" "${password}" --readonly
    else
      calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- add "${user}" "${password}"
    fi
  fi
  calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- readonly "${user}" "${readonly}"
  calibre-server --userdb "${BOOKS_USERDB}" --manage-users -- change_set_password "${user}" "${can_change_password}"
}

ensure_calibre_userdb() {
  ensure_calibre_user "${CALIBRE_OPDS_USER}" "${CALIBRE_OPDS_PASSWORD}" set reset
  ensure_calibre_user "${CALIBRE_ADMIN_USER}" "${CALIBRE_ADMIN_PASSWORD}" reset set
  chown books:books "${BOOKS_USERDB}"
  chmod 0660 "${BOOKS_USERDB}"
}

render_template() {
  local src="$1"
  local dest="$2"
  local tmp
  tmp="$(mktemp)"
  sed \
    -e "s|__BOOKS_ALLOWED_EMAIL__|${BOOKS_ALLOWED_EMAIL}|g" \
    -e "s|__BOOKS_PROXY_PORT__|${BOOKS_PROXY_PORT}|g" \
    -e "s|__CALIBRE_PORT__|${CALIBRE_PORT}|g" \
    -e "s|__CALIBRE_WEB_PORT__|${CALIBRE_WEB_PORT}|g" \
    -e "s|__BOOKS_PORTAL_PORT__|${BOOKS_PORTAL_PORT}|g" \
    -e "s|__KOSYNC_PORT__|${KOSYNC_PORT}|g" \
    -e "s|__READEST_PORT__|${READEST_PORT}|g" \
    -e "s|__READEST_KONG_PORT__|${READEST_KONG_PORT}|g" \
    -e "s|__READEST_MINIO_PORT__|${READEST_MINIO_PORT}|g" \
    "${src}" > "${tmp}"
  install -m 0644 "${tmp}" "${dest}"
  rm -f "${tmp}"
}

install_wrappers() {
  install -d -m 0755 "${OPT_BIN}"
  install -m 0755 "${ROOT_DIR}/bin/books-annas" "${OPT_BIN}/books-annas"
  install -m 0755 "${ROOT_DIR}/bin/books-import" "${OPT_BIN}/books-import"
  install -m 0755 "${ROOT_DIR}/bin/books-sync-fixture" "${OPT_BIN}/books-sync-fixture"
  install -m 0755 "${ROOT_DIR}/bin/books-users" "${OPT_BIN}/books-users"
  install -m 0755 "${ROOT_DIR}/bin/books-portal" "${OPT_BIN}/books-portal"
}

ensure_kosync_image() {
  systemctl enable --now docker >/dev/null 2>&1 || true
  docker pull "${KOSYNC_IMAGE}"
}

install_readest_stack() {
  install -d -o books -g books -m 0750 "${READEST_DIR}"
  install -m 0644 "${ROOT_DIR}/config/readest/compose.yaml.template" "${READEST_DIR}/compose.yaml"
  cp -a "${ROOT_DIR}/config/readest/volumes/." "${READEST_DIR}/volumes/"
  chown -R books:books "${READEST_DIR}/volumes"
  find "${READEST_DIR}/volumes" -type d -exec chmod 0755 {} +
  find "${READEST_DIR}/volumes" -type f -exec chmod 0644 {} +
  install -m 0640 -o root -g books "${ENV_FILE}" "${READEST_DIR}/.env"
  docker pull "${READEST_IMAGE}"
  docker pull "${READEST_POSTGRES_IMAGE}"
  docker pull "${READEST_KONG_IMAGE}"
  docker pull "${READEST_GOTRUE_IMAGE}"
  docker pull "${READEST_POSTGREST_IMAGE}"
  docker pull "${READEST_MINIO_IMAGE}"
  docker pull "${READEST_MC_IMAGE}"
}

install_services() {
  install -m 0644 "${ROOT_DIR}/config/systemd/books-calibre.service" "${SYSTEMD_UNIT}"
  install -m 0644 "${ROOT_DIR}/config/systemd/books-calibre-web.service" "${CALIBRE_WEB_SYSTEMD_UNIT}"
  install -m 0644 "${ROOT_DIR}/config/systemd/books-portal.service" "${PORTAL_SYSTEMD_UNIT}"
  install -m 0644 "${ROOT_DIR}/config/systemd/books-kosync.service" "${KOSYNC_SYSTEMD_UNIT}"
  install -m 0644 "${ROOT_DIR}/config/systemd/books-readest.service" "${READEST_SYSTEMD_UNIT}"
  render_template "${ROOT_DIR}/config/nginx/books.conf.template" "${NGINX_CONF}"
  if [[ -L /etc/nginx/sites-enabled/default ]]; then
    rm -f /etc/nginx/sites-enabled/default
  fi
  systemctl daemon-reload
  nginx -t
  if [[ "${skip_start}" != true ]]; then
    systemctl enable books-calibre books-calibre-web books-portal books-kosync books-readest nginx
    systemctl restart books-calibre
    systemctl restart books-calibre-web
    systemctl restart books-portal
    systemctl restart books-kosync
    systemctl restart books-readest
    systemctl enable --now nginx
    systemctl reload nginx
  fi
}

install_skill() {
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    runuser -u "${SUDO_USER}" -- "${ROOT_DIR}/scripts/install-skill" || true
  fi
}

