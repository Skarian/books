#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_DIR=/etc/books
ENV_FILE="${BOOKS_ENV_FILE:-${ENV_DIR}/books.env}"
NON_INTERACTIVE=0
ENV_KEYS=(
  BOOKS_PUBLIC_HOST BOOKS_BIND_ADDR BOOKS_PROXY_PORT BOOKS_HOST_DATA_DIR
  BOOKS_DATA_DIR BOOKS_LIBRARY_DIR BOOKS_DOWNLOAD_DIR BOOKS_IMPORT_DIR
  BOOKS_LOG_DIR BOOKS_CONFIG_DIR BOOKS_USERDB BOOKS_STATE_FILE
  BOOKS_CALIBRE_LIBRARY_ID BOOKS_NODE_HOST BOOKS_NODE_PORT BOOKS_LOCAL_BASE_URL
  CALIBRE_PORT BOOKS_CALIBRE_URL CALIBRE_VERSION CALIBRE_ADMIN_USER
  CALIBRE_ADMIN_PASSWORD KOSYNC_IMAGE KOSYNC_INTERNAL_URL
  KOSYNC_ENABLE_REGISTRATION ANNAS_VERSION ANNAS_BASE_URL ANNAS_SECRET_KEY
  ANNAS_DOWNLOAD_PATH HARDCOVER_DAILY_DOWNLOAD_CAP HARDCOVER_SYNC_INTERVAL_SECONDS
  BOOKS_DEFAULT_LANGUAGE BOOKS_DEFAULT_TAGS BOOKS_UID BOOKS_GID
)

usage() {
  cat <<'EOF'
Usage: ./scripts/onboard [--non-interactive]

Creates the Books env file, data directories, Docker Compose stack, Calibre
admin user, and reader service reconciliation.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ ${EUID} -ne 0 ]]; then
  exec sudo -E "$0" "$@"
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --non-interactive)
      NON_INTERACTIVE=1
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 2
      ;;
  esac
done

load_existing_env() {
  if [[ -r "${ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
    set +a
  fi
}

rand_secret() {
  LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c "${1:-24}" || true
}

prompt_annas_key() {
  [[ "${NON_INTERACTIVE}" == "1" || -n "${ANNAS_SECRET_KEY:-}" || ! -t 0 ]] && return
  read -r -s -p "Anna's Archive API key [leave blank to skip for now]: " ANNAS_SECRET_KEY
  echo
}

shell_quote() {
  printf "'%s'" "${1//\'/\'\\\'\'}"
}

write_env() {
  install -d -m 0755 "${ENV_DIR}"
  umask 077
  {
    for key in "${ENV_KEYS[@]}"; do
      printf '%s=%s\n' "${key}" "$(shell_quote "${!key}")"
    done
  } > "${ENV_FILE}"
  chown "${SUDO_UID:-$(id -u)}:${SUDO_GID:-$(id -g)}" "${ENV_FILE}" 2>/dev/null || true
  chmod 0600 "${ENV_FILE}"
}

ensure_docker() {
  if command -v docker >/dev/null 2>&1 && docker compose version >/dev/null 2>&1; then
    return
  fi
  if command -v apt-get >/dev/null 2>&1; then
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y ca-certificates curl docker.io docker-compose-v2
  fi
  docker compose version >/dev/null
}

ensure_dirs() {
  local dir
  for dir in "${BOOKS_HOST_DATA_DIR}" "${BOOKS_HOST_DATA_DIR}/config" "${BOOKS_HOST_DATA_DIR}/library" "${BOOKS_HOST_DATA_DIR}/downloads" "${BOOKS_HOST_DATA_DIR}/import" "${BOOKS_HOST_DATA_DIR}/log" "${BOOKS_HOST_DATA_DIR}/kosync" "${BOOKS_HOST_DATA_DIR}/kosync/redis"; do
    install -d -m 0750 "${dir}"
    chown "${BOOKS_UID}:${BOOKS_GID}" "${dir}" 2>/dev/null || true
  done
  chown -R "${BOOKS_UID}:${BOOKS_GID}" "${BOOKS_HOST_DATA_DIR}/config" "${BOOKS_HOST_DATA_DIR}/library" "${BOOKS_HOST_DATA_DIR}/downloads" "${BOOKS_HOST_DATA_DIR}/import" "${BOOKS_HOST_DATA_DIR}/log" 2>/dev/null || true
  chmod 0770 "${BOOKS_HOST_DATA_DIR}/library" "${BOOKS_HOST_DATA_DIR}/downloads" "${BOOKS_HOST_DATA_DIR}/import" 2>/dev/null || true
}

compose() {
  docker compose --project-name books --project-directory "${ROOT_DIR}" -f "${ROOT_DIR}/compose.yaml" --env-file "${ENV_FILE}" "$@"
}

load_existing_env

BOOKS_PUBLIC_HOST="${BOOKS_PUBLIC_HOST:-books.example.com}"
BOOKS_BIND_ADDR="${BOOKS_BIND_ADDR:-127.0.0.1}"
BOOKS_PROXY_PORT="${BOOKS_PROXY_PORT:-8000}"
BOOKS_HOST_DATA_DIR="${BOOKS_HOST_DATA_DIR:-/srv/books}"
BOOKS_DATA_DIR="${BOOKS_DATA_DIR:-/srv/books}"
BOOKS_LIBRARY_DIR="${BOOKS_LIBRARY_DIR:-${BOOKS_DATA_DIR}/library}"
BOOKS_DOWNLOAD_DIR="${BOOKS_DOWNLOAD_DIR:-${BOOKS_DATA_DIR}/downloads}"
BOOKS_IMPORT_DIR="${BOOKS_IMPORT_DIR:-${BOOKS_DATA_DIR}/import}"
BOOKS_LOG_DIR="${BOOKS_LOG_DIR:-${BOOKS_DATA_DIR}/log}"
BOOKS_CONFIG_DIR="${BOOKS_CONFIG_DIR:-${BOOKS_DATA_DIR}/config}"
BOOKS_USERDB="${BOOKS_USERDB:-${BOOKS_CONFIG_DIR}/users.sqlite}"
BOOKS_STATE_FILE="${BOOKS_STATE_FILE:-${BOOKS_CONFIG_DIR}/state.json}"
BOOKS_CALIBRE_LIBRARY_ID="${BOOKS_CALIBRE_LIBRARY_ID:-library}"
BOOKS_NODE_HOST="${BOOKS_NODE_HOST:-0.0.0.0}"
BOOKS_NODE_PORT="${BOOKS_NODE_PORT:-8090}"
BOOKS_LOCAL_BASE_URL="${BOOKS_LOCAL_BASE_URL:-http://proxy:8000}"
CALIBRE_PORT="${CALIBRE_PORT:-8080}"
BOOKS_CALIBRE_URL="${BOOKS_CALIBRE_URL:-http://calibre:8080}"
CALIBRE_VERSION="${CALIBRE_VERSION:-9.9.0}"
CALIBRE_ADMIN_USER="${CALIBRE_ADMIN_USER:-books_admin}"
CALIBRE_ADMIN_PASSWORD="${CALIBRE_ADMIN_PASSWORD:-$(rand_secret 32)}"
KOSYNC_IMAGE="${KOSYNC_IMAGE:-koreader/kosync@sha256:bb3f13615365703315a43b9059f65e71e876440f867e23a42bf27f2fa18264e1}"
KOSYNC_INTERNAL_URL="${KOSYNC_INTERNAL_URL:-http://kosync:17200}"
KOSYNC_ENABLE_REGISTRATION="${KOSYNC_ENABLE_REGISTRATION:-true}"
ANNAS_VERSION="${ANNAS_VERSION:-v0.0.5}"
ANNAS_BASE_URL="${ANNAS_BASE_URL:-annas-archive.li}"
ANNAS_SECRET_KEY="${ANNAS_SECRET_KEY:-}"
ANNAS_DOWNLOAD_PATH="${ANNAS_DOWNLOAD_PATH:-${BOOKS_DOWNLOAD_DIR}}"
HARDCOVER_DAILY_DOWNLOAD_CAP="${HARDCOVER_DAILY_DOWNLOAD_CAP:-10}"
HARDCOVER_SYNC_INTERVAL_SECONDS="${HARDCOVER_SYNC_INTERVAL_SECONDS:-300}"
BOOKS_DEFAULT_LANGUAGE="${BOOKS_DEFAULT_LANGUAGE:-eng}"
BOOKS_DEFAULT_TAGS="${BOOKS_DEFAULT_TAGS:-agent-imported}"
BOOKS_UID="${BOOKS_UID:-1000}"
BOOKS_GID="${BOOKS_GID:-1000}"
prompt_annas_key

write_env
ensure_docker
ensure_dirs

compose build
compose run --rm --no-deps admin node src/cli.js bootstrap
compose up -d
compose run --rm admin node src/cli.js users reconcile || true
compose run --rm admin node src/cli.js health

echo "Books service configured."
echo "Local health: http://${BOOKS_BIND_ADDR}:${BOOKS_PROXY_PORT}/healthz"
echo "Readest Web URL: https://web.readest.com/"
echo "Catalog URL: https://${BOOKS_PUBLIC_HOST}/catalog"
echo "KOSync URL: https://${BOOKS_PUBLIC_HOST}/kosync"
