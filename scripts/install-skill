#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILL_SRC="${ROOT_DIR}/skills/books"
SKILLS_DIR="${CODEX_HOME:-${HOME}/.codex}/skills"
SKILL_DEST="${SKILLS_DIR}/books"

if [[ ! -d "${SKILL_SRC}" ]]; then
  echo "Missing skill source: ${SKILL_SRC}" >&2
  exit 1
fi

mkdir -p "${SKILLS_DIR}"
rm -rf "${SKILL_DEST}"
ln -s "${SKILL_SRC}" "${SKILL_DEST}"
echo "Installed books skill at ${SKILL_DEST}"
