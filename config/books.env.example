# Copy values into /etc/books/books.env by running ./scripts/onboard.
# Do not commit real secrets or downloaded books.

BOOKS_PUBLIC_HOST=books.exe.xyz
BOOKS_PROXY_PORT=8000

BOOKS_DATA_DIR=/srv/books
BOOKS_LIBRARY_DIR=/srv/books/library
BOOKS_DOWNLOAD_DIR=/srv/books/downloads
BOOKS_IMPORT_DIR=/srv/books/import
BOOKS_LOG_DIR=/srv/books/log
BOOKS_CONFIG_DIR=/srv/books/config
BOOKS_USERDB=/srv/books/config/users.sqlite
BOOKS_ACCOUNTS_DB=/srv/books/config/accounts.sqlite
BOOKS_CALIBRE_LIBRARY_ID=library
BOOKS_NODE_PORT=8090

CALIBRE_PORT=8080
CALIBRE_VERSION=9.9.0
CALIBRE_ADMIN_USER=books_admin
CALIBRE_ADMIN_PASSWORD=replace-me

KOSYNC_PORT=7200
KOSYNC_IMAGE=koreader/kosync@sha256:bb3f13615365703315a43b9059f65e71e876440f867e23a42bf27f2fa18264e1
KOSYNC_CONTAINER=books-kosync
KOSYNC_DATA_DIR=/srv/books/kosync
KOSYNC_LOG_DIR=/srv/books/log/kosync
KOSYNC_ENABLE_REGISTRATION=false

ANNAS_VERSION=v0.0.5
ANNAS_BASE_URL=annas-archive.li
ANNAS_SECRET_KEY=
ANNAS_DOWNLOAD_PATH=/srv/books/downloads

HARDCOVER_DAILY_DOWNLOAD_CAP=15

BOOKS_DEFAULT_LANGUAGE=eng
BOOKS_DEFAULT_TAGS=agent-imported
