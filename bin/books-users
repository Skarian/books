#!/usr/bin/env python3
import argparse
import base64
import datetime as dt
import hashlib
import json
import os
import re
import secrets
import sqlite3
import subprocess
import sys
from pathlib import Path

ENV_FILE = Path("/etc/books/books.env")


def load_env():
    env = {}
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            value = value.strip()
            if len(value) >= 2 and value[0] == value[-1] == "'":
                value = value[1:-1].replace("'\\''", "'")
            env[key] = value
    return env


ENV = load_env()
CONFIG_DIR = Path(ENV.get("BOOKS_CONFIG_DIR", "/srv/books/config"))
ACCOUNTS_DB = Path(ENV.get("BOOKS_ACCOUNTS_DB", str(CONFIG_DIR / "accounts.sqlite")))
REQUESTS_DIR = Path(ENV.get("BOOKS_REQUESTS_DIR", "/srv/books/requests"))
PUBLIC_HOST = ENV.get("BOOKS_PUBLIC_HOST", "books.exe.xyz")
USERDB = ENV.get("BOOKS_USERDB", "/srv/books/config/users.sqlite")
KOSYNC_CONTAINER = ENV.get("KOSYNC_CONTAINER", "books-kosync")
BOOKS_PROXY_PORT = ENV.get("BOOKS_PROXY_PORT", "8000")


def now():
    return dt.datetime.now(dt.UTC).replace(microsecond=0).isoformat()


def slugify(value):
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    if not slug:
        raise SystemExit("Could not derive a slug from that name.")
    return slug[:48]


WORDS = """
amber anchor apple autumn baker beacon bridge bright cabin cedar cherry circle
clear coffee comet cotton creek crystal daily delta desert ember engine feather
forest garden gentle golden harbor honest island lantern maple meadow mellow
mirror morning native ocean orange pepper planet pocket quiet river silver
simple steady summer sunset temple timber valley velvet window winter wonder
""".split()


def password():
    return base64.urlsafe_b64encode(secrets.token_bytes(18)).decode().rstrip("=")


def passphrase():
    return "-".join(secrets.choice(WORDS) for _ in range(4))


def md5(value):
    return hashlib.md5(value.encode("utf-8")).hexdigest()


def db():
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(ACCOUNTS_DB)
    conn.row_factory = sqlite3.Row
    conn.execute(
        """
        create table if not exists accounts (
          slug text primary key,
          display_name text not null,
          email text,
          status text not null default 'active',
          roles text not null default 'reader',
          login_user text unique,
          login_password text,
          opds_user text not null unique,
          opds_password text not null,
          kosync_user text not null unique,
          kosync_password text not null,
          kosync_userkey text not null,
          setup_user text not null unique,
          setup_password text not null,
          created_at text not null,
          updated_at text not null,
          disabled_at text,
          purged_at text
        )
        """
    )
    columns = {row["name"] for row in conn.execute("pragma table_info(accounts)").fetchall()}
    if "login_user" not in columns:
        conn.execute("alter table accounts add column login_user text")
    if "login_password" not in columns:
        conn.execute("alter table accounts add column login_password text")
    # Legacy installs may still have readest_email/readest_password columns from
    # the self-hosted Readest experiment. They are intentionally ignored.
    rows = conn.execute(
        "select slug, login_user, login_password from accounts"
    ).fetchall()
    for row in rows:
        updates = {}
        if not row["login_user"]:
            updates["login_user"] = row["slug"]
        if not row["login_password"]:
            updates["login_password"] = passphrase()
        if updates:
            updates["updated_at"] = now()
            assignments = ", ".join(f"{key}=?" for key in updates)
            conn.execute(
                f"update accounts set {assignments} where slug=?",
                [*updates.values(), row["slug"]],
            )
    conn.execute(
        """
        create table if not exists audit_log (
          id integer primary key autoincrement,
          created_at text not null,
          actor text not null,
          action text not null,
          target text not null,
          detail text not null default '{}'
        )
        """
    )
    conn.commit()
    return conn


def audit(conn, action, target, detail=None):
    conn.execute(
        "insert into audit_log(created_at, actor, action, target, detail) values(?,?,?,?,?)",
        (now(), os.environ.get("USER", "unknown"), action, target, json.dumps(detail or {})),
    )
    conn.commit()


def run(cmd, check=True):
    return subprocess.run(cmd, text=True, check=check, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def calibre_user_exists(user):
    result = run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "list"], check=False)
    return result.returncode == 0 and user in result.stdout.splitlines()


def calibre_set_user(user, pw, active=True):
    if calibre_user_exists(user):
        run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "chpass", user, pw])
    else:
        run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "add", user, pw, "--readonly"])
    run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "readonly", user, "set"])
    run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "change_set_password", user, "reset"])


def docker_redis(*args, check=True):
    return run(["docker", "exec", KOSYNC_CONTAINER, "redis-cli", "-n", "1", *args], check=check)


def kosync_set_user(user, userkey):
    docker_redis("SET", f"user:{user}:key", userkey)


def kosync_disable_user(user):
    docker_redis("DEL", f"user:{user}:key", check=False)


def kosync_purge_user(user):
    keys = docker_redis("--scan", "--pattern", f"user:{user}:*").stdout.splitlines()
    if keys:
        docker_redis("DEL", *keys, check=False)


def calibre_remove_user(user):
    if calibre_user_exists(user):
        run(["calibre-server", "--userdb", USERDB, "--manage-users", "--", "remove", user], check=False)


def service_user(row):
    return row["login_user"] or row["slug"]


def service_password(row):
    return row["login_password"] or row["opds_password"]


def get_account(conn, slug):
    row = conn.execute("select * from accounts where slug=?", (slug,)).fetchone()
    if not row:
        raise SystemExit(f"No account named {slug}.")
    return row


def cmd_init(_args):
    conn = db()
    conn.close()
    print(f"Initialized {ACCOUNTS_DB}")


def cmd_create(args):
    conn = db()
    slug = args.slug or slugify(args.name)
    exists = conn.execute("select 1 from accounts where slug=?", (slug,)).fetchone()
    if exists:
        raise SystemExit(f"Account already exists: {slug}")
    shared_pw = passphrase()
    roles = ["reader"]
    if args.upload:
        roles.append("uploader")
    created = now()
    conn.execute(
        """
        insert into accounts(
          slug, display_name, email, status, roles,
          login_user, login_password,
          opds_user, opds_password,
          kosync_user, kosync_password, kosync_userkey,
          setup_user, setup_password, created_at, updated_at
        ) values(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """,
        (
            slug,
            args.name,
            args.email,
            "active",
            ",".join(roles),
            slug,
            shared_pw,
            f"opds_{slug}",
            shared_pw,
            f"sync_{slug}",
            shared_pw,
            md5(shared_pw),
            f"setup_{slug}",
            shared_pw,
            created,
            created,
        ),
    )
    audit(conn, "create", slug, {"email": args.email, "roles": roles})
    conn.close()
    cmd_reconcile(argparse.Namespace(user=slug))
    cmd_show(argparse.Namespace(user=slug, json=False))


def cmd_list(_args):
    conn = db()
    rows = conn.execute(
        "select slug, display_name, email, status, roles from accounts order by display_name"
    ).fetchall()
    for row in rows:
        print(f"{row['slug']}\t{row['status']}\t{row['display_name']}\t{row['email'] or ''}\t{row['roles']}")


def account_payload(row):
    return {
        "slug": row["slug"],
        "display_name": row["display_name"],
        "email": row["email"],
        "status": row["status"],
        "roles": row["roles"],
        "setup_url": f"https://{PUBLIC_HOST}/setup/{row['slug']}",
        "login_user": service_user(row),
        "login_password": service_password(row),
        "readest_url": "https://web.readest.com/",
        "opds_url": f"https://{PUBLIC_HOST}/catalog",
        "opds_user": service_user(row),
        "opds_password": service_password(row),
        "kosync_url": f"https://{PUBLIC_HOST}/kosync",
        "kosync_user": service_user(row),
        "kosync_password": service_password(row),
        "setup_user": service_user(row),
        "setup_password": service_password(row),
    }


def cmd_show(args):
    conn = db()
    row = get_account(conn, args.user)
    payload = account_payload(row)
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print(f"{payload['display_name']} ({payload['slug']}) [{payload['status']}]")
        print(f"Setup: {payload['setup_url']}")
        print()
        print("Use this login for setup, the book catalog, and reading sync:")
        print(f"Username: {payload['login_user']}")
        print(f"Password: {payload['login_password']}")
        print()
        print(f"Readest: {payload['readest_url']}")
        print("Readest account: create or sign in with your own Readest account.")
        print()
        print(f"OPDS URL: {payload['opds_url']}")
        print()
        print(f"KOSync URL: {payload['kosync_url']}")


def cmd_disable(args):
    conn = db()
    row = get_account(conn, args.user)
    conn.execute(
        "update accounts set status='disabled', disabled_at=?, updated_at=? where slug=?",
        (now(), now(), row["slug"]),
    )
    audit(conn, "disable", row["slug"])
    conn.close()
    cmd_reconcile(argparse.Namespace(user=row["slug"]))


def cmd_rotate(args):
    conn = db()
    row = get_account(conn, args.user)
    service = args.service
    updates = {"updated_at": now()}
    if service in ("login", "all"):
        shared_pw = passphrase()
        updates["login_password"] = shared_pw
        updates["opds_password"] = shared_pw
        updates["kosync_password"] = shared_pw
        updates["kosync_userkey"] = md5(shared_pw)
        updates["setup_password"] = shared_pw
    assignments = ", ".join(f"{key}=?" for key in updates)
    conn.execute(
        f"update accounts set {assignments} where slug=?",
        [*updates.values(), row["slug"]],
    )
    audit(conn, "rotate", row["slug"], {"service": service})
    conn.close()
    cmd_reconcile(argparse.Namespace(user=row["slug"]))
    cmd_show(argparse.Namespace(user=row["slug"], json=False))


def cmd_purge(args):
    if not args.yes:
        raise SystemExit("Refusing to purge without --yes.")
    conn = db()
    row = get_account(conn, args.user)
    kosync_purge_user(row["kosync_user"])
    kosync_purge_user(service_user(row))
    calibre_remove_user(row["opds_user"])
    calibre_remove_user(service_user(row))
    audit(conn, "purge", row["slug"])
    conn.execute("delete from accounts where slug=?", (row["slug"],))
    conn.commit()
    conn.close()
    request_dir = REQUESTS_DIR / row["slug"]
    if request_dir.exists():
        for path in request_dir.glob("*.json"):
            path.unlink()
        try:
            request_dir.rmdir()
        except OSError:
            pass


def cmd_reconcile(args):
    conn = db()
    if args.user:
        rows = [get_account(conn, args.user)]
    else:
        rows = conn.execute("select * from accounts order by slug").fetchall()
    for row in rows:
        username = service_user(row)
        shared_pw = service_password(row)
        if row["status"] == "active":
            calibre_set_user(username, shared_pw, True)
            if row["opds_user"] != username:
                calibre_remove_user(row["opds_user"])
            kosync_set_user(username, md5(shared_pw))
            if row["kosync_user"] != username:
                kosync_disable_user(row["kosync_user"])
            print(f"reconciled active user {row['slug']}")
        else:
            calibre_set_user(username, password(), False)
            if row["opds_user"] != username:
                calibre_set_user(row["opds_user"], password(), False)
            kosync_disable_user(username)
            kosync_disable_user(row["kosync_user"])
            print(f"disabled service access for {row['slug']}")
    try:
        os.chown(ACCOUNTS_DB, 0, grp_id("books"))
        os.chmod(ACCOUNTS_DB, 0o640)
    except PermissionError:
        pass
    conn.close()


def grp_id(name):
    import grp

    return grp.getgrnam(name).gr_gid


def cmd_requests(args):
    REQUESTS_DIR.mkdir(parents=True, exist_ok=True)
    if args.request_cmd == "list":
        for path in sorted(REQUESTS_DIR.glob("*/*.json")):
            data = json.loads(path.read_text())
            print(f"{path}\t{data.get('status','new')}\t{data.get('user')}\t{data.get('title')}")
    elif args.request_cmd == "show":
        print(Path(args.path).read_text())
    elif args.request_cmd == "process":
        paths = [Path(args.path)] if args.path else sorted(REQUESTS_DIR.glob("*/*.json"))
        if not paths:
            print("No queued book requests.")
            return
        path = paths[0]
        data = json.loads(path.read_text())
        title = data.get("title", "").strip()
        if not title:
            raise SystemExit(f"Request has no title: {path}")
        data["status"] = "searched"
        data["searched_at"] = now()
        path.write_text(json.dumps(data, indent=2))
        print(f"Request: {title}")
        if data.get("notes"):
            print(f"Notes: {data['notes']}")
        print()
        print("Anna's Archive search:")
        result = run(["/opt/books/bin/books-annas", "book-search", f"{title} epub english"], check=False)
        if result.stdout:
            print(result.stdout)
        if result.stderr:
            print(result.stderr, file=sys.stderr)
        if result.returncode != 0:
            raise SystemExit(result.returncode)
        print("After choosing an authorized EPUB result:")
        print("./scripts/books anna book-download MD5_HASH filename.epub")
        print("./scripts/books import /srv/books/downloads/filename.epub")
    elif args.request_cmd == "mark":
        path = Path(args.path)
        data = json.loads(path.read_text())
        data["status"] = args.status
        data["updated_at"] = now()
        if args.note:
            data["owner_note"] = args.note
        path.write_text(json.dumps(data, indent=2))
        print(f"{path}\t{data['status']}\t{data.get('title')}")
    elif args.request_cmd == "fulfill":
        path = Path(args.path)
        data = json.loads(path.read_text())
        filename = args.filename
        if not filename.lower().endswith(".epub"):
            filename += ".epub"
        data["status"] = "downloading"
        data["selected_md5"] = args.md5
        data["selected_filename"] = filename
        data["updated_at"] = now()
        path.write_text(json.dumps(data, indent=2))
        run(["/opt/books/bin/books-annas", "book-download", args.md5, filename])
        download_path = str(Path(ENV.get("BOOKS_DOWNLOAD_DIR", "/srv/books/downloads")) / filename)
        run(["/opt/books/bin/books-import", download_path])
        data["status"] = "fulfilled"
        data["fulfilled_at"] = now()
        data["imported_path"] = download_path
        path.write_text(json.dumps(data, indent=2))
        print(f"Fulfilled {path}: {filename}")


def main():
    parser = argparse.ArgumentParser()
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init").set_defaults(func=cmd_init)
    create = sub.add_parser("create")
    create.add_argument("name")
    create.add_argument("--slug")
    create.add_argument("--email")
    create.add_argument("--upload", action="store_true")
    create.set_defaults(func=cmd_create)
    sub.add_parser("list").set_defaults(func=cmd_list)
    show = sub.add_parser("show")
    show.add_argument("user")
    show.add_argument("--json", action="store_true")
    show.set_defaults(func=cmd_show)
    disable = sub.add_parser("disable")
    disable.add_argument("user")
    disable.set_defaults(func=cmd_disable)
    rotate = sub.add_parser("rotate")
    rotate.add_argument("user")
    rotate.add_argument("service", choices=["login", "all"])
    rotate.set_defaults(func=cmd_rotate)
    purge = sub.add_parser("purge")
    purge.add_argument("user")
    purge.add_argument("--yes", action="store_true")
    purge.set_defaults(func=cmd_purge)
    reconcile = sub.add_parser("reconcile")
    reconcile.add_argument("user", nargs="?")
    reconcile.set_defaults(func=cmd_reconcile)
    requests = sub.add_parser("requests")
    rsub = requests.add_subparsers(dest="request_cmd", required=True)
    rsub.add_parser("list")
    show_req = rsub.add_parser("show")
    show_req.add_argument("path")
    process_req = rsub.add_parser("process")
    process_req.add_argument("path", nargs="?")
    mark_req = rsub.add_parser("mark")
    mark_req.add_argument("path")
    mark_req.add_argument("status", choices=["new", "searched", "fulfilled", "rejected", "done"])
    mark_req.add_argument("--note")
    fulfill_req = rsub.add_parser("fulfill")
    fulfill_req.add_argument("path")
    fulfill_req.add_argument("md5")
    fulfill_req.add_argument("filename")
    requests.set_defaults(func=cmd_requests)
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
