.wrap{max-width:1120px;margin:0 auto;padding:28px}
.top{display:flex;justify-content:space-between;gap:20px;align-items:flex-start;margin-bottom:24px}
.brand{font-size:28px;font-weight:720;letter-spacing:0}.muted{color:#676058}.nav{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end}
.hero{background:#fff;border:1px solid #ded8cf;border-radius:8px;padding:24px;margin-bottom:16px}.hero h1{margin:0 0 8px;font-size:32px;line-height:1.08}.hero p{max-width:760px;line-height:1.5}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(245px,1fr));gap:14px}.stack{display:grid;gap:14px}
