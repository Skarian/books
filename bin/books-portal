def db():
    conn = sqlite3.connect(ACCOUNTS_DB)
    conn.row_factory = sqlite3.Row
    return conn


def esc(value):
    return html.escape("" if value is None else str(value))


def now():
    return dt.datetime.now(dt.UTC).replace(microsecond=0).isoformat()


def request_files(slug=None):
    REQUESTS_DIR.mkdir(parents=True, exist_ok=True)
    pattern = f"{slug}/*.json" if slug else "*/*.json"
    return sorted(REQUESTS_DIR.glob(pattern), reverse=True)


def load_requests(slug=None):
    rows = []
    for path in request_files(slug):
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError:
            continue
        data["_path"] = str(path)
        rows.append(data)
    return rows


def status_class(status):
    if status in {"fulfilled", "done"}:
        return "ok"
    if status in {"rejected"}:
        return "bad"
    return "warn"


class Handler(BaseHTTPRequestHandler):
    server_version = "BooksPortal/1.0"

    def log_message(self, fmt, *args):
        sys.stderr.write("%s - %s\n" % (self.address_string(), fmt % args))

    def send_html(self, title, body, code=200):
        content = f"<!doctype html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1'><title>{esc(title)}</title><style>{STYLE}</style></head><body><main class='wrap'>{body}</main></body></html>".encode()
        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(content)))
        self.send_header("Cache-Control", "no-store")
        self.send_header("Referrer-Policy", "no-referrer")
        self.end_headers()
        self.wfile.write(content)

    def redirect(self, path):
        self.send_response(303)
        self.send_header("Location", path)
        self.end_headers()

    def owner(self):
        return self.headers.get("X-ExeDev-Email") == ALLOWED_EMAIL

    def require_owner(self):
        if self.owner():
            return True
        self.send_html("Forbidden", "<div class='card'><h1>Forbidden</h1></div>", 403)
        return False

    def setup_auth(self, slug):
        auth = self.headers.get("Authorization", "")
        if not auth.startswith("Basic "):
            self.send_response(401)
            self.send_header("WWW-Authenticate", 'Basic realm="Books setup"')
            self.end_headers()
            return None
        try:
            userpass = base64.b64decode(auth.split(" ", 1)[1]).decode()
            username, password = userpass.split(":", 1)
        except Exception:
            self.send_response(401)
            self.end_headers()
            return None
        conn = db()
        row = conn.execute("select * from accounts where slug=? and status='active'", (slug,)).fetchone()
        conn.close()
        if not row or username != row["setup_user"] or password != row["setup_password"]:
            self.send_response(401)
            self.send_header("WWW-Authenticate", 'Basic realm="Books setup"')
            self.end_headers()
            return None
        return row

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path.rstrip("/") or "/"
        if path == "/healthz":
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"ok\n")
        elif path == "/":
            self.home()
        elif path == "/guide":
            self.guide()
        elif path == "/users":
            self.users()
        elif path == "/requests":
            self.requests()
        elif path.startswith("/setup/"):
            self.setup_page(path.split("/", 2)[2])
        else:
            self.send_html("Not found", "<div class='card'><h1>Not found</h1></div>", 404)

    def do_POST(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path.rstrip("/")
        if path == "/api/kosync":
            self.readest_kosync_proxy()
        elif path.startswith("/setup/") and path.endswith("/request"):
            slug = path.split("/")[2]
            row = self.setup_auth(slug)
            if not row:
                return
            length = int(self.headers.get("Content-Length", "0"))
            form = urllib.parse.parse_qs(self.rfile.read(length).decode())
            title = form.get("title", [""])[0].strip()
            notes = form.get("notes", [""])[0].strip()
            legal = form.get("legal", [""])[0] == "yes"
            if not title or not legal:
                self.send_html("Book request", "<div class='card'><h1>Missing title or legal confirmation.</h1><p><a href='../%s'>Back</a></p></div>" % esc(row["slug"]), 400)
                return
            user_dir = REQUESTS_DIR / row["slug"]
            user_dir.mkdir(parents=True, exist_ok=True)
            request_id = now().replace(":", "").replace("+", "Z")
            payload = {"id": request_id, "created_at": now(), "status": "new", "user": row["slug"], "title": title, "notes": notes}
            (user_dir / f"{request_id}.json").write_text(json.dumps(payload, indent=2))
            self.redirect(f"/setup/{row['slug']}")
        else:
            self.send_html("Not found", "<div class='card'><h1>Not found</h1></div>", 404)

    def send_json(self, payload, code=200):
        content = json.dumps(payload).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(content)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(content)

    def readest_kosync_proxy(self):
        try:
            length = int(self.headers.get("Content-Length", "0"))
            payload = json.loads(self.rfile.read(length).decode())
        except Exception:
            self.send_json({"error": "Invalid JSON body"}, 400)
            return

        server_url = str(payload.get("serverUrl", "")).rstrip("/")
        endpoint = str(payload.get("endpoint", ""))
        method = str(payload.get("method", "GET")).upper()
        headers = payload.get("headers") or {}
        body = payload.get("body")

        try:
            parsed = urllib.parse.urlparse(server_url)
        except Exception:
            self.send_json({"error": "Invalid serverUrl"}, 400)
            return

        if parsed.scheme != "https" or parsed.netloc != PUBLIC_HOST or parsed.path.rstrip("/") != "/kosync":
            self.send_json({"error": "This Readest instance only proxies its own KOSync server."}, 400)
            return
        if method not in {"GET", "POST", "PUT"}:
            self.send_json({"error": "Invalid method"}, 400)
            return
        if not any(re.fullmatch(pattern, endpoint) for pattern in (r"/users/auth", r"/users/create", r"/syncs/progress", r"/syncs/progress/[^/]+")):
            self.send_json({"error": "Invalid endpoint"}, 400)
            return

        target = f"https://127.0.0.1:{KOSYNC_PORT}{endpoint}"
        outbound_headers = {
            "Accept": "application/vnd.koreader.v1+json",
            "Content-Type": "application/json",
        }
        for key, value in headers.items():
            lk = str(key).lower()
            if lk in {"x-auth-user", "x-auth-key", "authorization"}:
                outbound_headers[str(key)] = str(value)
        data = json.dumps(body).encode() if body is not None else None
        request = urllib.request.Request(target, data=data, method=method, headers=outbound_headers)

        try:
            context = ssl._create_unverified_context()
            with urllib.request.urlopen(request, context=context, timeout=15) as response:
                content = response.read()
                code = response.status
                content_type = response.headers.get("Content-Type", "application/json")
        except urllib.error.HTTPError as error:
            content = error.read()
            code = error.code
            content_type = error.headers.get("Content-Type", "application/json")
        except Exception as error:
            self.send_json({"error": "Proxy request failed", "details": str(error)}, 502)
            return

        self.send_response(code)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(content)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(content)

    def chrome(self, title, inner):
        return f"<div class='top'><div><div class='brand'>Neil's Books</div><div class='muted'>{esc(title)}</div></div><nav class='nav'><a href='/'>Home</a><a href='/guide'>Guide</a><a href='/users'>Users</a><a href='/requests'>Requests</a><a href='/calibre/'>Calibre</a></nav></div>{inner}"

    def home(self):
        if not self.require_owner():
            return
        conn = db()
        users = conn.execute("select count(*) from accounts where status='active'").fetchone()[0]
        conn.close()
        requests = load_requests()
        open_requests = sum(1 for row in requests if row.get("status", "new") not in {"fulfilled", "done", "rejected"})
        body = f"""
        <section class='hero'><h1>Neil's Books</h1><p>A self-hosted EPUB library for the family. Readest handles browser and app reading, Calibre serves the catalog, and KOSync keeps reading position synced across devices.</p><div class='row'><span class='pill'>{users} active reader{"s" if users != 1 else ""}</span><span class='pill'>{open_requests} open request{"s" if open_requests != 1 else ""}</span><span class='pill'>Catalog on /catalog</span><span class='pill'>Progress sync on /kosync</span></div><div class='actions'><a class='button' href='/library'>Read in browser</a><a class='button secondary' href='/guide'>Set up a device</a></div></section>
        <div class='grid'>
          <section class='card'><h2>Calibre admin</h2><p>Use this when you need metadata, imports, or the older Calibre-Web UI.</p><a class='button' href='/calibre/'>Open Calibre</a></section>
          <section class='card'><h2>Family readers</h2><p>Add a reader, rotate credentials, or open their private setup page.</p><a class='button' href='/users'>View users</a></section>
          <section class='card'><h2>Book requests</h2><p>Requests from setup pages wait here until an agent searches, downloads, and imports an authorized EPUB.</p><a class='button' href='/requests'>Review requests</a></section>
        </div>
        """
        self.send_html("Home", self.chrome("home", body))

    def guide(self):
        if not self.require_owner():
            return
        body = f"""
        <div class='stack steps'>
        <section class='hero'><h1>Set up reading</h1><p>Each person has a private setup page with their own passwords. The URLs are shared, but the logins are not.</p><div class='grid'><div class='field'><b>Readest Web</b><span>https://{PUBLIC_HOST}/library</span></div><div class='field'><b>Book catalog</b><span>https://{PUBLIC_HOST}/catalog</span></div><div class='field'><b>Reading-place sync</b><span>https://{PUBLIC_HOST}/kosync</span></div></div></section>
        <section class='card step'><h2>Readest on iPad, Android, Mac, and Windows</h2><ol><li>Sign in with the Readest email and password from the reader's setup page.</li><li>Open Settings, then Integrations.</li><li>Under Content Sources, open OPDS Catalogs and tap Add Catalog.</li><li>Under Reading Sync, open KOReader Sync and connect to KOSync.</li><li>After it connects, leave Checksum Method set to File Content.</li></ol></section>
        <section class='card step'><h2>XTEink X4 with CrossPoint</h2><p>Add the book catalog URL and use the reader's OPDS login. If CrossPoint exposes KOReader-compatible progress sync, use the same KOSync server and that reader's KOSync login.</p></section>
        <section class='card step'><h2>KOReader</h2><p>Add the catalog as an OPDS catalog and configure Progress Sync with the KOSync values. KOReader is the reference app for validating sync behavior.</p></section>
        <section class='card step'><h2>What to avoid</h2><p>Use <span class='code'>https://{PUBLIC_HOST}/kosync</span> exactly. Do not add <span class='code'>/api</span>, <span class='code'>/v1</span>, or <span class='code'>/healthcheck</span>. For progress sync, download the same EPUB from this catalog on each device.</p></section>
        </div>
        """
        self.send_html("Guide", self.chrome("device setup", body))

    def users(self):
        if not self.require_owner():
            return
        conn = db()
        rows = conn.execute("select * from accounts where status!='deleted' order by display_name").fetchall()
        conn.close()
        table = "<table><tr><th>User</th><th>Status</th><th>Readest</th><th>Setup page</th><th>Setup login</th><th>CLI</th></tr>"
        for row in rows:
            table += f"<tr><td>{esc(row['display_name'])}<br><span class='muted'>{esc(row['email'])}</span></td><td><span class='pill'>{esc(row['status'])}</span></td><td><div class='code'>{esc(row['readest_email'])}</div><div class='code'>{esc(row['readest_password'])}</div></td><td><a href='/setup/{esc(row['slug'])}'>/setup/{esc(row['slug'])}</a></td><td><div class='code'>{esc(row['setup_user'])}</div><div class='code'>{esc(row['setup_password'])}</div></td><td><pre class='code'>./scripts/books users show {esc(row['slug'])}</pre><pre class='code'>./scripts/books users rotate {esc(row['slug'])} all</pre><pre class='code'>./scripts/books users reconcile {esc(row['slug'])}</pre></td></tr>"
        table += "</table>"
        body = f"<section class='card'><h1>Family readers</h1><p>Create users by asking Codex, or run <span class='code'>./scripts/books users create \"Name\" --email person@example.com</span>. Reconcile pushes that account into Calibre OPDS, Readest, and KOSync.</p>{table}</section>"
        self.send_html("Users", self.chrome("family users", body))

    def requests(self):
        if not self.require_owner():
            return
        REQUESTS_DIR.mkdir(parents=True, exist_ok=True)
        rows = []
        for data in load_requests():
            status = data.get("status", "new")
            path = data.get("_path", "")
            rows.append(f"<tr><td>{esc(data.get('created_at'))}</td><td>{esc(data.get('user'))}</td><td>{esc(data.get('title'))}<br><span class='muted'>{esc(data.get('notes'))}</span></td><td><span class='pill {status_class(status)}'>{esc(status)}</span></td><td><pre class='code'>./scripts/books requests process {esc(path)}</pre><pre class='code'>./scripts/books requests fulfill {esc(path)} MD5_HASH filename.epub</pre></td></tr>")
        table = "<table><tr><th>Time</th><th>User</th><th>Request</th><th>Status</th><th>Agent command</th></tr>%s</table>" % "".join(rows)
        body = f"<section class='card'><h1>Book requests</h1><p>Requests are stored as JSON and processed by the repo CLI. The user has already confirmed legal access before a request is queued.</p>{table}</section>"
        self.send_html("Requests", self.chrome("book requests", body))

    def setup_page(self, slug):
        row = self.setup_auth(slug)
        if not row:
            return
        rows = []
        for data in load_requests(row["slug"]):
            status = data.get("status", "new")
            rows.append(f"<tr><td>{esc(data.get('created_at'))}</td><td>{esc(data.get('title'))}</td><td><span class='pill {status_class(status)}'>{esc(status)}</span></td><td>{esc(data.get('owner_note'))}</td></tr>")
        request_table = "<p class='muted'>No requests yet.</p>" if not rows else "<table><tr><th>Time</th><th>Book</th><th>Status</th><th>Note</th></tr>%s</table>" % "".join(rows)
        body = f"""
        <div class='top'><div><div class='brand'>Neil's Books for {esc(row['display_name'])}</div><div class='muted'>shared books, private reading place</div></div></div>
        <section class='hero'><h1>Start here</h1><p>Readest is the easiest place to begin. Use the catalog for books and KOSync for your reading place. Keep these credentials private; they are just for you.</p><div class='actions'><a class='button' href='/library'>Read in browser</a></div></section>
        <div class='grid steps'>
          <section class='card step'><h2>Sign in to Readest</h2><p>Use this for Readest Web and the Readest apps.</p><ol><li>Open the URL below.</li><li>Tap Sign in to sync your library.</li><li>Enter this email and password.</li></ol><div class='field'><b>URL</b><span>https://{PUBLIC_HOST}/library</span></div><div class='field'><b>Email</b><span>{esc(row['readest_email'])}</span></div><div class='field'><b>Password</b><span>{esc(row['readest_password'])}</span></div></section>
          <section class='card step'><h2>Add the book catalog</h2><p>This is where Readest, CrossPoint, and KOReader find books.</p><ol><li>In Readest, open Settings, then Integrations.</li><li>Under Content Sources, open OPDS Catalogs.</li><li>Tap Add Catalog and enter these values.</li></ol><div class='field'><b>Catalog URL</b><span>https://{PUBLIC_HOST}/catalog</span></div><div class='field'><b>Username</b><span>{esc(row['opds_user'])}</span></div><div class='field'><b>Password</b><span>{esc(row['opds_password'])}</span></div></section>
          <section class='card step'><h2>Turn on progress sync</h2><p>This keeps your reading place synced across Readest, CrossPoint, and KOReader.</p><ol><li>In Readest, open Settings, then Integrations.</li><li>Under Reading Sync, open KOReader Sync.</li><li>Enter these values and tap Connect.</li><li>After it connects, leave Checksum Method set to File Content.</li></ol><div class='field'><b>KOSync server</b><span>https://{PUBLIC_HOST}/kosync</span></div><div class='field'><b>Username</b><span>{esc(row['kosync_user'])}</span></div><div class='field'><b>Password</b><span>{esc(row['kosync_password'])}</span></div></section>
        </div>
        <section class='card' style='margin-top:14px'><h2>Device notes</h2><p><b>iPad, Android, Mac, Windows:</b> use Readest first. <b>XTEink X4 with CrossPoint:</b> add the catalog and use KOSync if the sync settings are available. <b>KOReader:</b> catalog plus Progress Sync is the reference setup.</p><p class='muted'>Leave WebDAV off unless we add it later for a specific device problem.</p></section>
        <section class='card' style='margin-top:14px'><h2>Request a book</h2><form method='post' action='/setup/{esc(row['slug'])}/request'><label>Title / author</label><input name='title' required><label>Notes</label><textarea name='notes' rows='4'></textarea><label><input style='width:auto' type='checkbox' name='legal' value='yes' required> I own this, it is public domain, Creative Commons, or I am otherwise allowed to access it.</label><button class='button' type='submit'>Send request</button></form></section>
        <section class='card' style='margin-top:14px'><h2>Your requests</h2>{request_table}</section>
        """
        self.send_html("Setup", body)


if __name__ == "__main__":
    ThreadingHTTPServer(("127.0.0.1", PORT), Handler).serve_forever()
