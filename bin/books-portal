#!/usr/bin/env python3
import base64
import datetime as dt
import html
import json
import os
import re
import sqlite3
import ssl
import sys
import urllib.parse
import urllib.request
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

ENV_FILE = Path("/etc/books/books.env")


def load_env():
    env = {}
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            value = value.strip()
            if len(value) >= 2 and value[0] == value[-1] == "'":
                value = value[1:-1].replace("'\\''", "'")
            env[key] = value
    return env


ENV = load_env()
PUBLIC_HOST = ENV.get("BOOKS_PUBLIC_HOST", "books.exe.xyz")
ALLOWED_EMAIL = ENV.get("BOOKS_ALLOWED_EMAIL", "neil.skaria@gmail.com")
ACCOUNTS_DB = Path(ENV.get("BOOKS_ACCOUNTS_DB", "/srv/books/config/accounts.sqlite"))
REQUESTS_DIR = Path(ENV.get("BOOKS_REQUESTS_DIR", "/srv/books/requests"))
PORT = int(ENV.get("BOOKS_PORTAL_PORT", "8090"))
KOSYNC_PORT = int(ENV.get("KOSYNC_PORT", "7200"))


STYLE = """
body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f6f4ef;color:#191815}
