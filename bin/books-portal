.field{border:1px solid #e2dbd1;background:#fbfaf7;border-radius:8px;padding:10px;margin:8px 0}.field b{display:block;font-size:12px;color:#635b52;margin-bottom:4px;text-transform:uppercase;letter-spacing:.04em}.field span{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;word-break:break-all}
.steps{counter-reset:step}.step{position:relative;padding-left:48px}.step:before{counter-increment:step;content:counter(step);position:absolute;left:18px;top:18px;width:24px;height:24px;border-radius:50%;background:#1f5f55;color:#fff;display:grid;place-items:center;font-weight:700;font-size:13px}
.ok{color:#1f5f55}.warn{color:#8a4d14}.bad{color:#9d1d20}
