#!/usr/bin/env bash
set -euo pipefail

if [[ ${EUID} -ne 0 ]]; then
  exec sudo "$0" "$@"
fi

ENV_FILE=/etc/books/books.env
if [[ ! -r "${ENV_FILE}" ]]; then
  echo "Missing ${ENV_FILE}. Run ./scripts/onboard first." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${ENV_FILE}"
set +a

ANNAS_BIN=/opt/books/bin/annas-mcp
if [[ ! -x "${ANNAS_BIN}" ]]; then
  echo "Missing ${ANNAS_BIN}. Run ./scripts/onboard first." >&2
  exit 1
fi

if [[ -z "${ANNAS_SECRET_KEY:-}" ]]; then
  echo "ANNAS_SECRET_KEY is not configured in ${ENV_FILE}." >&2
  echo "Run ./scripts/onboard and enter your Anna's Archive API key." >&2
  exit 1
fi

install -d -o books -g books -m 2770 "${ANNAS_DOWNLOAD_PATH:-${BOOKS_DOWNLOAD_DIR}}"
cd /opt/books/bin
exec runuser -u books -- env \
  ANNAS_SECRET_KEY="${ANNAS_SECRET_KEY}" \
  ANNAS_DOWNLOAD_PATH="${ANNAS_DOWNLOAD_PATH:-${BOOKS_DOWNLOAD_DIR}}" \
  ANNAS_BASE_URL="${ANNAS_BASE_URL:-annas-archive.li}" \
  "${ANNAS_BIN}" "$@"
