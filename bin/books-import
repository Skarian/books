#!/usr/bin/env bash
set -euo pipefail

if [[ ${EUID} -ne 0 ]]; then
  exec sudo "$0" "$@"
fi

ENV_FILE=/etc/books/books.env
if [[ ! -r "${ENV_FILE}" ]]; then
  echo "Missing ${ENV_FILE}. Run ./scripts/onboard first." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${ENV_FILE}"
set +a

convert=false
files=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --convert)
      convert=true
      shift
      ;;
    -h|--help)
      echo "Usage: books-import [--convert] FILE [FILE ...]"
      echo "Imports EPUB files into the calibre library. --convert converts non-EPUB files first."
      exit 0
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

if [[ ${#files[@]} -eq 0 ]]; then
  echo "No files supplied. Usage: books-import [--convert] FILE [FILE ...]" >&2
  exit 2
fi

install -d -o books -g books -m 2770 "${BOOKS_LIBRARY_DIR}" "${BOOKS_IMPORT_DIR}"
password_file="$(mktemp)"
cleanup() {
  rm -f "${password_file}"
}
trap cleanup EXIT
chmod 0600 "${password_file}"
printf '%s' "${CALIBRE_ADMIN_PASSWORD}" > "${password_file}"
calibre_library_url="http://127.0.0.1:${CALIBRE_PORT}/#${BOOKS_CALIBRE_LIBRARY_ID:-library}"

for input in "${files[@]}"; do
  if [[ ! -f "${input}" ]]; then
    echo "Not a file: ${input}" >&2
    exit 1
  fi

  ext="${input##*.}"
  ext="${ext,,}"
  import_file="${input}"

  if [[ "${ext}" != "epub" ]]; then
    if [[ "${convert}" != true ]]; then
      echo "Skipping non-EPUB file without --convert: ${input}" >&2
      continue
    fi
    safe_name="$(basename "${input%.*}")"
    import_file="${BOOKS_IMPORT_DIR}/${safe_name}.epub"
    ebook-convert "${input}" "${import_file}"
  fi

  calibredb \
    --with-library "${calibre_library_url}" \
    --username "${CALIBRE_ADMIN_USER}" \
    --password "<f:${password_file}>" \
    add \
    --automerge overwrite \
    --languages "${BOOKS_DEFAULT_LANGUAGE:-eng}" \
    --tags "${BOOKS_DEFAULT_TAGS:-agent-imported}" \
    "${import_file}"
done
